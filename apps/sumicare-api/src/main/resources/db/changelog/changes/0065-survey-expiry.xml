<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="0065-1-survey-invitation-expiry" author="sumicare">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="survey_invitations" columnName="expires_at"/>
            </not>
        </preConditions>
        <addColumn tableName="survey_invitations">
            <column name="expires_at" type="timestamp"/>
        </addColumn>
        <sql>
            UPDATE survey_invitations
            SET expires_at = COALESCE(sent_at, now()) + interval '7 days'
            WHERE expires_at IS NULL
        </sql>
    </changeSet>

</databaseChangeLog>
