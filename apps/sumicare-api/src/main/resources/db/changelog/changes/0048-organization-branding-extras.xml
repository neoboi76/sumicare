<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="0048-1-organization-login-background" author="sumicare">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="organizations" columnName="login_background_url"/>
            </not>
        </preConditions>
        <addColumn tableName="organizations">
            <column name="login_background_url" type="VARCHAR(512)"/>
        </addColumn>
    </changeSet>

