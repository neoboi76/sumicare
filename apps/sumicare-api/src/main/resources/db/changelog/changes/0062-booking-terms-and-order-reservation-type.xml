<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="0062-1-booking-terms-accepted-at" author="sumicare">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="bookings" columnName="terms_accepted_at"/>
            </not>
        </preConditions>
        <addColumn tableName="bookings">
            <column name="terms_accepted_at" type="timestamp"/>
        </addColumn>
    </changeSet>

    <changeSet id="0062-2-order-reservation-type" author="sumicare">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="orders" columnName="reservation_type"/>
            </not>
        </preConditions>
        <addColumn tableName="orders">
            <column name="reservation_type" type="varchar(16)"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
