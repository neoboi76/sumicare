<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="0044-1-feedback-read-state" author="sumicare">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="feedback" columnName="read_at"/>
            </not>
        </preConditions>
        <addColumn tableName="feedback">
            <column name="read_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="read_by_user_id" type="uuid"/>
        </addColumn>
    </changeSet>

    <changeSet id="0044-2-feedback-read-index" author="sumicare">
        <preConditions onFail="MARK_RAN">
            <not>
                <indexExists indexName="idx_feedback_org_unread"/>
            </not>
        </preConditions>
        <createIndex tableName="feedback" indexName="idx_feedback_org_unread">
            <column name="organization_id"/>
            <column name="read_at"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
