<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="0031-1-order-items-room-type" author="sumicare">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="order_items" columnName="room_type"/>
            </not>
        </preConditions>
        <addColumn tableName="order_items">
            <column name="room_type" type="VARCHAR(20)" defaultValue="COMMON">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="0031-2-order-items-room-type-charge" author="sumicare">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="order_items" columnName="room_type_charge"/>
            </not>
        </preConditions>
        <addColumn tableName="order_items">
            <column name="room_type_charge" type="NUMERIC(12,2)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>
