<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="0035-1-treatment-slip-extension-minutes" author="sumicare">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="treatment_slips" columnName="extension_minutes"/>
            </not>
        </preConditions>
        <addColumn tableName="treatment_slips">
            <column name="extension_minutes" type="INT"/>
        </addColumn>
    </changeSet>

    <changeSet id="0035-2-treatment-slip-client-gender" author="sumicare">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="treatment_slips" columnName="client_gender"/>
            </not>
        </preConditions>
        <addColumn tableName="treatment_slips">
            <column name="client_gender" type="VARCHAR(1)"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
