<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="0024-1-orders-last-edited-by" author="sumicare">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="orders" columnName="last_edited_by_user_id"/>
            </not>
        </preConditions>
        <addColumn tableName="orders">
            <column name="last_edited_by_user_id" type="uuid"/>
        </addColumn>
    </changeSet>

    <changeSet id="0024-2-orders-last-edited-by-backfill" author="sumicare">
        <sql>
            UPDATE orders
            SET last_edited_by_user_id = cashier_user_id
            WHERE last_edited_by_user_id IS NULL
              AND cashier_user_id IS NOT NULL;
        </sql>
    </changeSet>

    <changeSet id="0024-3-drop-cashier-shifts" author="sumicare">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="cashier_shifts"/>
        </preConditions>
        <dropTable tableName="cashier_shifts"/>
    </changeSet>

</databaseChangeLog>
