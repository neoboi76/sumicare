<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="0034-1-deactivate-vip-service" author="sumicare">
        <update tableName="services_catalogue">
            <column name="is_active" valueBoolean="false"/>
            <where>code = 'VIP'</where>
        </update>
    </changeSet>

    <changeSet id="0034-2-drop-services-is-vip" author="sumicare">
        <preConditions onFail="MARK_RAN">
            <columnExists tableName="services_catalogue" columnName="is_vip"/>
        </preConditions>
        <dropColumn tableName="services_catalogue" columnName="is_vip"/>
    </changeSet>

</databaseChangeLog>
