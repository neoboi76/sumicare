<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="0028-1-orders-extension-amount" author="sumicare">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="orders" columnName="extension_amount"/>
            </not>
        </preConditions>
        <addColumn tableName="orders">
            <column name="extension_amount" type="NUMERIC(12,2)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="0028-2-orders-extension-minutes" author="sumicare">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="orders" columnName="extension_minutes"/>
            </not>
        </preConditions>
        <addColumn tableName="orders">
            <column name="extension_minutes" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>
