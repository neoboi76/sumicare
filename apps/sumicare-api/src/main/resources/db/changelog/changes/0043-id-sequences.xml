<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="0043-1-id-sequences" author="sumicare">
        <createSequence sequenceName="or_number_seq" startValue="100000" incrementBy="1"/>
        <createSequence sequenceName="receipt_number_seq" startValue="100000" incrementBy="1"/>
        <createSequence sequenceName="tsn_seq" startValue="1" incrementBy="1"/>
        <rollback>
            <dropSequence sequenceName="or_number_seq"/>
            <dropSequence sequenceName="receipt_number_seq"/>
            <dropSequence sequenceName="tsn_seq"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
