# =============================================================================
# SumiCare Environment Configuration
# Copy this file to .env and fill in the real values.
# NEVER commit .env to version control.
# =============================================================================

# --- Server ---
SERVER_PORT=8080
API_PORT=8080

# --- Database (PostgreSQL) ---
DB_URL=jdbc:postgresql://localhost:5432/sumicare
DB_USERNAME=sumicare
DB_PASSWORD=

POSTGRES_DB=sumicare
POSTGRES_USER=sumicare
POSTGRES_PASSWORD=

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- JWT ---
# Must be at least 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRY_MS=900000
JWT_REFRESH_EXPIRY_MS=604800000

# --- CORS ---
# Use * for development. Set to your exact frontend origin in production.
CORS_ALLOWED_ORIGINS=*

# --- Email (SMTP) ---
# For development: use Mailtrap (https://mailtrap.io)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=noreply@sumicare.app

# --- Application Base URL ---
# Used in email verification links. No trailing slash.
APP_PUBLIC_BASE_URL=http://localhost:4200

# --- Payments ---
# Stripe test keys: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# PayMongo test keys: https://dashboard.paymongo.com/developers
PAYMONGO_SECRET_KEY=sk_test_
PAYMONGO_WEBHOOK_SECRET=

# --- Biometrics ---
BIOMETRICS_MODE=webhook
BIOMETRICS_SHARED_KEY=
BIOMETRICS_POLLING_URL=
BIOMETRICS_POLLING_API_KEY=
BIOMETRICS_DATABASE_URL=
BIOMETRICS_DATABASE_USERNAME=
BIOMETRICS_DATABASE_PASSWORD=

# --- AI (optional) ---
ANTHROPIC_API_KEY=
